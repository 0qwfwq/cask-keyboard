<!--
  Minimalistic monochrome clipboard used by the keyboard's tools row. Stroke-only so it matches the
  flat, single-colour look of the translate glyph; the ImageView tints it to the current theme text
  colour at runtime.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- board -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineJoin="round"
        android:pathData="M6.5,4 H17.5 A2,2 0 0 1 19.5,6 V19 A2,2 0 0 1 17.5,21 H6.5 A2,2 0 0 1 4.5,19 V6 A2,2 0 0 1 6.5,4 Z" />
    <!-- clip -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineJoin="round"
        android:pathData="M9.5,3 H14.5 A1,1 0 0 1 15.5,4 V5 A1,1 0 0 1 14.5,6 H9.5 A1,1 0 0 1 8.5,5 V4 A1,1 0 0 1 9.5,3 Z" />
    <!-- content lines -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M8.5,11 L15.5,11" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M8.5,14.5 L13,14.5" />
</vector>
