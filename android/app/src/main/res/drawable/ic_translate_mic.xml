<!--
  Microphone glyph for the translate-mode "read aloud" (TTS) buttons sitting inside each text box.
  Filled capsule body + stroked stand so it reads clearly at small sizes; tinted to the theme at
  runtime (accent while speaking).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- capsule body -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,3 A3,3 0 0 1 15,6 V11 A3,3 0 0 1 9,11 V6 A3,3 0 0 1 12,3 Z" />
    <!-- stand arc -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M6.5,11 A5.5,5.5 0 0 0 17.5,11" />
    <!-- stem -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M12,16.5 L12,20" />
    <!-- base -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M8.5,20 L15.5,20" />
</vector>
