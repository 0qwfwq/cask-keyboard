<!--
  Minimalistic monochrome "web / internet" globe used by the keyboard's tools row. Stroke-only so it
  matches the flat, single-colour look of the translate glyph; the ImageView tints it to the current
  theme text colour at runtime.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- outer circle -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M12,3 A9,9 0 1,0 12,21 A9,9 0 1,0 12,3 Z" />
    <!-- equator -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M3,12 L21,12" />
    <!-- meridian (vertical ellipse) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M12,3 C7.5,7 7.5,17 12,21 C16.5,17 16.5,7 12,3 Z" />
</vector>
