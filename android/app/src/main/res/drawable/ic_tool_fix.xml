<!--
  Minimalistic monochrome "fix" wand used by the keyboard's tools row: a magic wand with sparkles,
  for the one-tap on-device clean-up of the typed text. Stroke-only so it matches the flat,
  single-colour look of the other tool glyphs; the ImageView tints it to the theme text colour.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- wand shaft -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M4,20 L14.5,9.5" />
    <!-- wand tip -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M14.5,9.5 L17,7" />
    <!-- large sparkle (top right) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M19.5,2.5 L19.5,7.5 M17,5 L22,5" />
    <!-- small sparkle (upper left) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M7,3.5 L7,7.5 M5,5.5 L9,5.5" />
    <!-- tiny sparkle (right) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M20.5,12.5 L20.5,15.5 M19,14 L22,14" />
</vector>
