<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Downloaded GIFs live in cacheDir/gifs and are shared to the target app via FileProvider. -->
    <cache-path name="gifs" path="gifs/" />
    <!-- Clipboard-history images live in filesDir/clipboard and are pasted via rich-content insert. -->
    <files-path name="clipboard" path="clipboard/" />
</paths>
